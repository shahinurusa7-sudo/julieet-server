# Server Configuration
PORT=3000
NODE_ENV=production

# Firebase Admin SDK Configuration
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option 2: Service account JSON as environment variable (for deployment)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_SOURCE=env

# Firebase Project Configuration
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# MongoDB Configuration (for message queue)
# Local: mongodb://localhost:27017/lovebirds
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/lovebirds
MONGODB_URI=mongodb://localhost:27017/lovebirds

# Message queue encryption key (required in production)
# Use a long random secret (32+ chars recommended)
OFFLINE_MSG_ENCRYPTION_KEY=replace_with_a_long_random_secret

# CORS Configuration
# Comma-separated list of allowed origins (or use * for all)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SMTP / Welcome Email Configuration
WELCOME_EMAIL_ENABLED=true
SMTP_HOST=mail.julieet.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@julieet.com
SMTP_PASS=replace_with_your_smtp_password
SMTP_FROM_EMAIL=no-reply@julieet.com
SMTP_FROM_NAME=Julieet Team
SMTP_REPLY_TO=support@julieet.com

# Welcome email branding
COMPANY_NAME=Julieet
CEO_NAME=Shahinur Alam
CEO_TITLE=Chief Executive Officer
APP_LOGIN_URL=https://julieet.com

# Keep SMTP_PASS only in your local .env file or deployment secret store.
